{
  "expo": {
    "name": "SikJipSa",
    "slug": "sikjipsa",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "sikjipsa",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sikjipsa.app",
      "icon": {
        "light": "./assets/icon.png",
        "dark": "./assets/icon-dark.png"
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "위치 정보로 오늘의 날씨를 반영해 식물별 물주기를 더 정확하게 추천해드려요.",
        "NSPhotoLibraryUsageDescription": "식물 사진을 등록하거나 성장 기록에 사진을 추가할 때 사진첩에 접근해요.",
        "NSCameraUsageDescription": "식물 사진을 촬영해서 바로 등록할 때 카메라를 사용해요.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.sikjipsa.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F5F1EA"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "READ_MEDIA_IMAGES"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "imageWidth": 240,
          "resizeMode": "contain",
          "backgroundColor": "#F5F1EA",
          "dark": {
            "image": "./assets/splash-dark.png",
            "backgroundColor": "#15181A"
          }
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.1094704094747-in0ll3499v83v8o8apstf0oghmb0l7jp"
        }
      ],
      [
        "@react-native-seoul/kakao-login",
        {
          "kakaoAppKey": "c4a67adeae4c366973ccba084ba425e1"
        }
      ],
      "./plugins/withModularHeaders"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "supabaseUrl": "",
      "supabaseAnonKey": "",
      "router": {},
      "eas": {
        "projectId": "90004c30-1f1c-411a-8df0-79b8a2b9ad95"
      }
    },
    "owner": "karan1284",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/90004c30-1f1c-411a-8df0-79b8a2b9ad95"
    }
  }
}
